{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "npm run format 2>/dev/null || true",
                        "statusMessage": "Formatting..."
                    }
                ]
            }
        ]
    }
}
